# Sao chép file này thành .env rồi điền thông tin thật vào
# Copy this file to .env and fill in your values

# Token lấy từ @BotFather trên Telegram (bắt buộc)
TELEGRAM_BOT_TOKEN=your_token_here

# Đường dẫn file database (mặc định: univer_all_in_one.db)
# UNIVER_DB_PATH=univer_all_in_one.db

# Port cho HTML dashboard (mặc định: 8080)
# HTML_PORT=8080
