# Sao chép file này thành .env rồi điền thông tin thật vào
# Copy this file to .env and fill in your values

# Token lấy từ @BotFather trên Telegram (bắt buộc)
TELEGRAM_BOT_TOKEN=your_token_here

# Đường dẫn file database (mặc định: univer_all_in_one.db)
# UNIVER_DB_PATH=univer_all_in_one.db

# Port cho HTML dashboard (mặc định: 8080)
# HTML_PORT=8080

# Secret token bảo vệ dashboard khi dùng Cloudflare Tunnel (nên đặt)
# URL sẽ cần thêm ?token=xxx  —  để trống = không bảo vệ
# DASHBOARD_SECRET=mat_khau_kho_doan

# ID kênh Telegram nhận thông báo thu/chi (mặc định dùng CHANNEL_CHAT_ID)
# Có thể là số âm (-1001xxxxxxxxx) hoặc @username kênh công khai
# CHANNEL_CHAT_ID=-1001974996093
# FINANCE_CHANNEL_ID=-1001974996093
