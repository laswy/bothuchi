# Sao chép file này thành .env rồi điền thông tin thật vào
# Copy this file to .env and fill in your values

# Token lấy từ @BotFather trên Telegram (bắt buộc)
TELEGRAM_BOT_TOKEN=your_token_here

# ── Webhook mode ────────────────────────────────────────────
# Để trống = dùng polling (chạy tại máy)
# Điền URL công khai = tự động dùng webhook (deploy trên server)
#
# WEBHOOK_URL=https://mybot.up.railway.app
#
# Port webhook lắng nghe (mặc định: PORT nếu có, hoặc 8443)
# Railway/Render/fly.io tự set PORT — không cần điền
# WEBHOOK_PORT=8443
#
# Token bí mật Telegram gửi kèm mỗi update (tùy chọn nhưng nên đặt)
# WEBHOOK_SECRET=random_string_kho_doan

# ── Dashboard ───────────────────────────────────────────────
# Port cho HTML dashboard (mặc định: 8080)
# HTML_PORT=8080

# Secret token bảo vệ dashboard (URL cần thêm ?token=xxx)
# DASHBOARD_SECRET=mat_khau_kho_doan

# ── Kênh Telegram ───────────────────────────────────────────
# ID kênh nhận thông báo crypto / thu chi
# CHANNEL_CHAT_ID=-1001974996093
# FINANCE_CHANNEL_ID=-1001974996093

# ── Database ────────────────────────────────────────────────
# UNIVER_DB_PATH=univer_all_in_one.db
